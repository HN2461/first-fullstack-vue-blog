{
  "name": "personal-blog-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#config/*": "./src/config/*.js",
    "#constants/*": "./src/constants/*.js",
    "#modules/*": "./src/modules/*",
    "#utils/*": "./src/utils/*",
    "#middlewares/*": "./src/middlewares/*"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "create:admin": "node src/scripts/createAdmin.js",
    "migrate": "node src/scripts/migrateArticles.js",
    "migrate:draft": "node src/scripts/migrateArticles.js --draft",
    "migrate:dry-run": "node src/scripts/migrateArticles.js --dry-run",
    "migrate:audit": "node src/scripts/migrateArticles.js --audit",
    "migrate:repair": "node src/scripts/migrateArticles.js --repair-existing",
    "fix:timestamps": "node src/scripts/fixArticleTimestamps.js",
    "update:frontend-paths": "node src/scripts/updateFrontendPathReferences.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "svg-captcha": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.2.0",
    "supertest": "^7.1.4",
    "nodemon": "^3.1.10",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
